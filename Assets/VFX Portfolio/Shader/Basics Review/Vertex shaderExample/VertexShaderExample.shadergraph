{
    "m_SGVersion": 0,
    "m_Type": "UnityEditor.ShaderGraph.StickyNoteData",
    "m_ObjectId": "809a665b738d4667885ca488706b0250",
    "m_Title": "Sine on Y",
    "m_Content": "By placing the movement direction and the speed float into a sine we get a wave over that amount of time on those vertexes. By plugging it into the y vector of a vector 3 we get height. Creating the wave. ",
